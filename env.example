# --- LLM APIs ---
# Claude API key for agentic tool-use (hard filter decisions, data cleaning)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key for text-embedding-3-small (neighborhood profile embeddings)
OPENAI_API_KEY=sk-...

# --- Model config (optional overrides) ---
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Neighborhood embeddings (Ranking page + cluster notes cache) ---
# openai | sentence_transformers | st | auto
#   auto: use OpenAI when OPENAI_API_KEY is set, otherwise sentence-transformers.
# EMBEDDING_BACKEND=openai
# SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
