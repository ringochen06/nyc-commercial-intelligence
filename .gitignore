outputs/**
!outputs/**/
claude.md

# Stray cluster cache if dev ran Streamlit with cwd under tests/
tests/outputs/

# Frontend (Next.js / Vercel)
frontend/node_modules
frontend/.next
frontend/out
frontend/.vercel
frontend/.env.local
frontend/.env.*.local
frontend/*.tsbuildinfo
