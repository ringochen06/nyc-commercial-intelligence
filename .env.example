# --- LLM APIs ---
# Claude API key for agentic tool-use (hard filter decisions, data cleaning)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key for text-embedding-3-small (neighborhood profile embeddings)
OPENAI_API_KEY=sk-...

# --- Model config (optional overrides) ---
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_BACKEND=auto

# LOCAL_EMBEDDING_MODEL_DIR=../all-MiniLM-L6-v2
# Put local model on ../ and use relative path, or absolute path if preferred.
