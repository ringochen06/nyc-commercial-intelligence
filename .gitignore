.venv/
venv/
__pycache__/

# Secrets & local environment (template stays tracked)
.env
.env.*
!.env.example
.envrc
*.py[cod]
.pytest_cache/
.ruff_cache/
.DS_Store

# Raw data: CSVs etc. stay local (see data/raw/README.MD). CDTA shapefile is small (~1.5MB) and tracked.
data/raw/**
!data/raw/.gitkeep
!data/raw/README.MD
!data/raw/nyc_boundaries/
!data/raw/nyc_boundaries/.gitkeep
!data/raw/nyc_boundaries/nycdta2020.*

# Processed pipeline outputs are versioned so clones can run the app without re-running ETL.
outputs/models/*
!outputs/models/.gitkeep
outputs/embeddings/*
!outputs/embeddings/.gitkeep
outputs/figures/*
!outputs/figures/.gitkeep
claude.md
