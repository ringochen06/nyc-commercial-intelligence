# --- LLM APIs ---
# Claude API key for agentic tool-use (Ranking page optional panel)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (optional). When set, neighborhood embeddings use OpenAI by default; when unset, local sentence-transformers.
OPENAI_API_KEY=sk-...

# --- Model config (optional) ---
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Neighborhood embeddings (Ranking + ``python -m src.embeddings``) ---
# Default: omit EMBEDDING_BACKEND → OpenAI if OPENAI_API_KEY is set, else sentence-transformers.
# Backup / force local-only (no OpenAI for embeddings):
# EMBEDDING_BACKEND=sentence_transformers

# Optional: override local model name when using sentence-transformers
# SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# --- FastAPI backend (Railway) ---
# Comma-separated list of allowed frontend origins for CORS.
# Set this on Railway to your Vercel URL(s), e.g.:
# FRONTEND_ORIGINS=https://nyc-commercial.vercel.app,https://nyc-commercial-git-main.vercel.app
FRONTEND_ORIGINS=http://localhost:3000

# Railway sets PORT automatically; uvicorn reads it via the Procfile / railway.json startCommand.

# --- Supabase (optional, used by /api/rank when both are set) ---
# When SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are set on Railway, /api/rank
# calls public.match_neighborhoods (pgvector cosine + filters in SQL) instead of
# loading the embeddings cache and DuckDB in-process. Falls back to CSV otherwise.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=ey...                 # server-only, bypasses RLS
# SUPABASE_ANON_KEY=ey...                          # not used by the backend; for the frontend if you wire it up later
